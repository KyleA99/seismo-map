{
    "openapi": "3.0.0",
    "info": {
        "title": "Earthquake Tracker API",
        "version": "1.0.0",
        "description": "An API for tracking recent earthquake data from the USGS earthquakes API."
    },
    "servers":
    [
        {
            "url": "http://localhost:4000/api",
            "description": "Local server"
        }
    ],
    "paths": {
        "/earthquakes": {
            "get": {
                "summary": "Get recent USGS earthquake data",
                "tags": ["Earthquakes"],
                "parameters":
                [
                    {
                        "name": "starttime",
                        "in": "query",
                        "description": "Starting time for the earthquake dataset",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "format": "date-time",
                            "example": "2025-01-01T00:00:00Z"
                        }
                    },
                    {
                        "name": "endtime",
                        "in": "query",
                        "description": "Ending time for the earthquake dataset",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "format": "date-time",
                            "example": "2025-01-05T00:00:00Z"
                        }
                    },
                    {
                        "name": "latitude",
                        "in": "query",
                        "description": "Latitude to be used for a radius search",
                        "required": false,
                        "schema": {
                            "type": "number",
                            "format": "float",
                            "minimum": -90,
                            "maximum": 90,
                            "example": 34.052235
                        }
                    },
                    {
                        "name": "longitude",
                        "in": "query",
                        "description": "Longitude to be used for a radius search",
                        "required": false,
                        "schema": {
                            "type": "number",
                            "format": "float",
                            "minimum": -180,
                            "maximum": 180,
                            "example": -118.243683
                        }
                    },
                    {
                        "name": "maxradiuskm",
                        "in": "query",
                        "description": "Maximum radius (kilometers) to be used for a radius search",
                        "required": false,
                        "schema": {
                            "type": "number",
                            "format": "float",
                            "example": 150.00
                        }
                    },
                    {
                        "name": "minmagnitude",
                        "in": "query",
                        "description": "Minimum magnitude of the earthquake(s)",
                        "required": false,
                        "schema": {
                            "type": "number",
                            "format": "float",
                            "example": 1.0
                        }
                    },
                    {
                        "name": "maxmagnitude",
                        "in": "query",
                        "description": "Maximum magnitude of the earthquake",
                        "required": false,
                        "schema": {
                            "type": "number",
                            "format": "float",
                            "example": 9.5
                        }
                    },
                    {
                        "name": "limit",
                        "in": "query",
                        "description": "Number of earthquake records to return",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "example": 10
                        }
                    },
                    {
                        "name": "orderby",
                        "in": "query",
                        "description": "Ordering of the earthquake datapoints",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "enum":
                            [
                                "time",
                                "time-asc",
                                "magnitude",
                                "magnitude-asc"
                            ],
                            "example": "time"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "A list of recent earthquakes",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/Earthquake"
                                    }
                                }
                            }
                        }
                    }
                }
            },
            "post": {
                "summary": "Insert earthquake data",
                "tags": ["Earthquakes"],
                "requestBody": {
                    "description": "User's local data",
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/UserLocalData"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Successful"
                    }
                }
            }
        },
        "/earthquakes/init": {
            "get": {
                "summary": "Get earthquake  data",
                "tags": ["Earthquakes"],
                "parameters":
                [
                    {
                        "name": "latitude",
                        "in": "query",
                        "description": "Latitude to be used for a radius search",
                        "required": false,
                        "schema": {
                            "type": "number",
                            "format": "float",
                            "minimum": -90,
                            "maximum": 90,
                            "example": 34.052235
                        }
                    },
                    {
                        "name": "longitude",
                        "in": "query",
                        "description": "Longitude to be used for a radius search",
                        "required": false,
                        "schema": {
                            "type": "number",
                            "format": "float",
                            "minimum": -180,
                            "maximum": 180,
                            "example": -118.243683
                        }
                    },
                    {
                        "name": "maxradiuskm",
                        "in": "query",
                        "description": "Maximum radius (kilometers) to be used for a radius search",
                        "required": false,
                        "schema": {
                            "type": "number",
                            "format": "float",
                            "example": 2500.00
                        }
                    },
                    {
                        "name": "limit",
                        "in": "query",
                        "description": "Number of earthquake records to return",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "example": 100
                        }
                    },
                    {
                        "name": "orderby",
                        "in": "query",
                        "description": "Ordering of the earthquake datapoints",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "enum":
                            [
                                "time",
                                "time-asc",
                                "magnitude",
                                "magnitude-asc"
                            ],
                            "example": "time"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "A list of the initialized earthquake data",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/Earthquake"
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "Earthquake": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string",
                        "description": "Unique identifier of the earthquake"
                    },
                    "magnitude": {
                        "type": "number",
                        "description": "Magnitude of the earthquake"
                    },
                    "location": {
                        "type": "string",
                        "description": "Location description of the earthquake"
                    },
                    "depth": {
                        "type": "number",
                        "description": "Depth of the earthquake in kilometers"
                    },
                    "time": {
                        "type": "string",
                        "format": "date-time",
                        "description": "Timestamp of the earthquake"
                    }
                }
            },
            "UserLocalData": {
                "type": "object",
                "properties": {
                    "latitude": {
                        "type": "number",
                        "format": "float",
                        "description": "Latitude to be used for a radius search",
                        "minimum": -90,
                        "maximum": 90,
                        "example": 37.7749
                    },
                    "longitude": {
                        "type": "number",
                        "format": "float",
                        "description": "Longitude to be used for a radius search",
                        "minimum": -180,
                        "maximum": 180,
                        "example": -122.4194
                    },
                    "maxradiuskm": {
                        "type": "number",
                        "format": "float",
                        "description": "Maximum radius (kilometers) to be used for a radius search",
                        "minimum": -180,
                        "maximum": 5000,
                        "example": 1000
                    },
                    "limit": {
                        "type": "integer",
                        "example": 10,
                        "description": "Number of earthquake records to return"
                    }
                }
            }
        }
    }
}
