{
    "openapi": "3.0.0",
    "info": {
        "title": "Earthquake Tracker API",
        "version": "1.0.0",
        "description": "An API for tracking recent earthquake data from the USGS earthquakes API."
    },
    "servers": [
        {
            "url": "http://localhost:4000/api",
            "description": "Local server"
        }],
    "paths": {
        "/earthquakes": {
            "get": {
                "summary": "Get recent earthquakes (eventually modify this to be our init call)",
                "tags": ["Earthquakes"],
                "responses": {
                    "200": {
                        "description": "A list of recent earthquakes",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/Earthquake"
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "Earthquake": {
                "type": "object",
                "properties": {
                    "mag": {
                    "type": "number",
                        "description": "Magnitude of the earthquake"
                    },
                    "time": {
                        "type": "string",
                        "format": "date-time",
                        "description": "Timestamp of the earthquake"
                    },
                    "location": {
                        "type": "string",
                        "description": "Location description of the earthquake"
                    },
                    "depth": {
                        "type": "number",
                        "description": "Depth of the earthquake in kilometers (is this correct units?)"
                    }
                }
            }
        }
    }
}
